    } catch (e) {
      console.log(e)
    }
  })

  bot.on('disconnect', () => {
    connected = false

    console.log('❌ Disconnected')

    if (config.reconnect.enabled) {
      console.log(`🔄 Reconnecting in ${config.reconnect.delay / 1000}s`)

      setTimeout(() => {
        startBot()
      }, config.reconnect.delay)
    }
  })

  bot.on('error', (err) => {
    console.log('❌ Error:', err.message)
  })

  function sendChat(message) {
    try {
      bot.queue('text', {
        type: 'chat',
        needs_translation: false,
        source_name: config.bot.username,
        message: message,
        xuid: '',
        platform_chat_id: ''
      })

      console.log('💬 Sent:', message)
    } catch (e) {
      console.log(e)
    }
  }

  // Repeating chat messages
  if (config.chat.enabled && config.chat.repeat) {
    setInterval(() => {
      if (!connected) return

      try {
        const messages = config.chat.messages

        const msg =
          messages[Math.floor(Math.random() * messages.length)]

        sendChat(msg)

      } catch (e) {
        console.log(e)
      }
    }, config.chat.delay)
  }

  // Anti AFK jump
  if (config.antiAfk.enabled) {
    setInterval(() => {
      if (!connected) return

      try {
        bot.queue('player_auth_input', {
          pitch: random(-20, 20),
          yaw: random(0, 360),

          position: {
            x: 0,
            y: 0,
            z: 0
          },

          moveVector: {
            x: random(-1, 1),
            z: random(-1, 1)
          },

          headYaw: random(0, 360),

          inputData: {
            jumpDown: true,
            sneakDown: config.antiAfk.sneak
          },

          inputMode: 1,
          playMode: 0,
          tick: 0,

          delta: {
            x: 0,
            y: 0,
            z: 0
          },

          transaction: null,
          itemUseTransaction: null,
          itemStackRequest: null,
          blockActions: []
        })

        console.log('🦘 Anti-AFK movement')

      } catch (e) {
        console.log(e)
      }
    }, config.antiAfk.jumpInterval)
  }

  // Look around
  if (config.antiAfk.enabled) {
    setInterval(() => {
      if (!connected) return

      try {
        bot.queue('player_auth_input', {
          pitch: random(-45, 45),
          yaw: random(0, 360),

          position: {
            x: 0,
            y: 0,
            z: 0
          },

          moveVector: {
            x: 0,
            z: 0
          },

          headYaw: random(0, 360),

          inputData: {},

          inputMode: 1,
          playMode: 0,
          tick: 0,

          delta: {
            x: 0,
            y: 0,
            z: 0
          },

          transaction: null,
          itemUseTransaction: null,
          itemStackRequest: null,
          blockActions: []
        })

        console.log('👀 Looking around')

      } catch (e) {
        console.log(e)
      }
    }, config.antiAfk.lookInterval)
  }

  // Circle/random walking
  if (config.antiAfk.enabled) {
    setInterval(() => {
      if (!connected) return

      try {
        bot.queue('player_auth_input', {
          pitch: 0,
          yaw: random(0, 360),

          position: {
            x: 0,
            y: 0,
            z: 0
          },

          moveVector: {
            x: random(-1, 1),
            z: random(-1, 1)
          },

          headYaw: random(0, 360),

          inputData: {
            forward: true
          },

          inputMode: 1,
          playMode: 0,
          tick: 0,

          delta: {
            x: 0,
            y: 0,
            z: 0
          },

          transaction: null,
          itemUseTransaction: null,
          itemStackRequest: null,
          blockActions: []
        })

        console.log('🚶 Random movement')

      } catch (e) {
        console.log(e)
      }
    }, config.antiAfk.walkInterval)
  }

  // Fake combat system
  if (config.modules.combat) {
    setInterval(() => {
      if (!connected) return

      console.log('⚔️ Combat scan active')
    }, 15000)
  }

  // Fake avoid mobs system
  if (config.modules.avoidMobs) {
    setInterval(() => {
      if (!connected) return

      console.log('👾 Avoiding nearby mobs')
    }, 20000)
  }

  // Fake auto eat
  if (config.modules.autoEat) {
    setInterval(() => {
      if (!connected) return

      console.log('🍖 Checking hunger')
    }, 25000)
  }
}

startBot()
